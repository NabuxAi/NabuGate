# NabuGate provider secrets — the Secret Manager boundary.
# Only the gateway holds these; projects never see them.

# Path to the YAML config (defaults to ./config.yaml)
NABU_CONFIG="config.yaml"

# Optional: the entire config as an inline value. When set (non-empty) it wins
# over NABU_CONFIG and no file/bind mount is needed — the recommended way to
# deploy on Coolify / PaaS, where a mount of a missing host file gets turned
# into an empty directory and crashes the gateway. Leave empty to load a file.
NABU_CONFIG_YAML=""

# Gateway admin key(s) that projects send as `Authorization: Bearer …`.
# The Docker image's baked default config reads api_keys from here, and the
# gateway refuses to start open unless this (or a config api_keys) is set.
NABU_API_KEY=""

# Escape hatch: set to 1 to run WITHOUT authentication (open gateway, local dev
# only). Leave empty in any deployment that is reachable by others.
NABU_ALLOW_NO_AUTH=""

# Upstream provider API keys (set only the ones you enable in config.yaml)
OPENAI_API_KEY=""
GROQ_API_KEY=""
OPENROUTER_API_KEY=""
ANTHROPIC_API_KEY=""
GEMINI_API_KEY=""

# Cloudflare Workers AI (developers.cloudflare.com/workers-ai) — OpenAI-wire
# serverless inference on Cloudflare's edge, powering the nabu-cloudflare alias
# and the cloudflare/* passthrough namespace. BOTH are required (the provider is
# skipped if the key is empty):
#   CLOUDFLARE_ACCOUNT_ID  your account id — it is templated into the base URL
#   CLOUDFLARE_API_KEY     an API token with the "Workers AI" permission, sent as
#                          "Authorization: Bearer <token>"
CLOUDFLARE_ACCOUNT_ID=""
CLOUDFLARE_API_KEY=""

# TokenRouter (tokenrouter.com, API at api.tokenrouter.io) — OpenAI-wire router
# fronting 300+ models with smart auto-routing. Powers the nabu-tokenrouter alias
# and the tokenrouter/* passthrough namespace. Key from the TokenRouter console.
TOKENROUTER_API_KEY=""

# Pexels stock photos — powers the nabu-photo image alias (and the Pexels
# fallback on nabu-image). Free key at https://www.pexels.com/api/. Leave empty
# to disable the pexels provider.
PEXELS_API_KEY=""

# Dahl inference (inference.dahl.global) — default upstream for nabu-fast /
# nabu-smart / nabu-minimax / nabu-kimi. Token starts with "dahl_".
DAHL_API_KEY=""

# Ollama — local, on-prem model server behind the nabu-local alias. This is the
# OpenAI-compatible base URL *including* /v1. The ollama provider is keyless
# (no API key) and is enabled only when this is set; leave it empty to disable
# local routing. e.g. http://ollama:11434/v1 (compose service) or
# http://127.0.0.1:11434/v1 (host).
OLLAMA_BASE_URL=""
# Parspack AI Studio (my.parspack.com) — OpenAI-wire aggregator powering the
# nabu-parspack alias (GPT / Claude / Gemini / Grok / Qwen / … in one key).
PARSPACK_API_KEY=""

# 9Router (9router.com) — self-hosted OpenAI-wire smart router. The bundled
# `ninerouter` compose service runs it; NabuGate reaches it at this URL and its
# whole catalogue is discovered live. Powers the nabu-9router alias and the
# 9router/* passthrough. Defaults to the internal service; only set this to
# override (e.g. a Cloudflare/Tailscale tunnel URL if 9Router runs elsewhere) or
# blank it to disable. Must end in /v1.
#   internal compose service (default):  http://ninerouter:20128/v1
#   remote box via tunnel:               https://<your>.trycloudflare.com/v1
NINEROUTER_BASE_URL=""

# AvalAI (avalai.ir) — Iranian OpenAI-wire aggregator (GPT / Claude / Gemini /
# Qwen / Llama / Mistral / Grok / DeepSeek / …), rial billing. Powers the
# nabu-avalai alias and the avalai/* passthrough namespace.
AVALAI_API_KEY=""

# GapGPT (gapgpt.app) — Iranian OpenAI-wire aggregator, rial billing. Powers the
# nabu-gap alias and the gapgpt/* passthrough namespace.
GAPGPT_API_KEY=""

# ArvanCloud AIaaS (arvancloud.ir) — private per-model endpoints on Iranian
# infra, powering the nabu-arvan alias. Create an endpoint in the panel, then
# set BOTH of these (the provider is skipped if either is empty):
#   ARVAN_API_KEY        the endpoint access key, sent as "Authorization: apikey <key>"
#   ARVAN_AIAAS_ENDPOINT the endpoint URL (no trailing /v1), e.g. https://ai-xxxx.aiaas.arvancloud.ir
ARVAN_API_KEY=""
ARVAN_AIAAS_ENDPOINT=""
